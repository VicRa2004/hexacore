generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  Entidades principales
// ─────────────────────────────────────────────

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String
  password String
  isActive Boolean @default(true) @map("is_active")

  // Relaciones N-a-N gestionadas por tablas intermedias explícitas
  roles            UserRole[]
  directPermissions UserPermission[]

  @@map("users")
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique // e.g., 'ADMIN', 'MOD', 'USER'

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

/// Permiso atómico: combinación única de recurso + acción.
/// Ejemplo: resource="turnos", action="create"
model Permission {
  id       Int    @id @default(autoincrement())
  resource String // e.g., "turnos", "users"
  action   String // e.g., "create", "read", "update", "delete"

  roles RolePermission[]
  users UserPermission[]

  @@unique([resource, action])
  @@map("permissions")
}

// ─────────────────────────────────────────────
//  Tablas intermedias (N-a-N explícitas)
// ─────────────────────────────────────────────

/// Asigna roles a usuarios
model UserRole {
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

/// Permisos que posee un rol completo
model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Permisos directos o excepcionales por usuario (pueden conceder O denegar)
model UserPermission {
  userId       Int     @map("user_id")
  permissionId Int     @map("permission_id")
  /// true = conceder, false = denegar (override sobre el rol)
  granted      Boolean @default(true)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

